# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# PostgreSQL (Render provides this)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=3000
NODE_ENV=production

# Trading Config
DEFAULT_SLIPPAGE_CENTS=2
ORDER_TTL_SECONDS=10
FEE_RATE=0.02
PLATFORM_FEE_SHARE=0.50
SERVER_OWNER_FEE_SHARE=0.30
CREATOR_FEE_SHARE=0.20

# AMM Config (Logarithmic Market Scoring Rule)
AMM_INITIAL_LIQUIDITY=1000
AMM_SUBSIDY=100
